  "plugins": [
    {
      "name": "vgc-coach-codex",
      "runtime": "codex",
      "manifest_path": ".codex-plugin/plugin.json",
      "description": "Pokemon Champions coaching skills for Codex.",
      "keywords": [
        "pokemon",
        "vgc",
        "codex",
        "coaching",
        "champions"
      ],
      "brand_color": "#FF6B35",
      "runtime_docs": [
        "docs/runtime/codex.md",
        "docs/runtime/codex/skills/README.md"
      ],
      "default_prompt_skills": [
        "vgc-meta-research",
        "vgc-team-builder",
        "vgc-team-audit"
      ],
      "capabilities": [
        "Interactive",
        "Knowledge"
      ]
    },
    {
      "name": "vgc-coach-claude",
      "runtime": "claude",
      "manifest_path": ".claude-plugin/plugin.json",
      "description": "Pokemon Champions coaching skills for Claude Code.",
      "keywords": [
        "pokemon",
        "vgc",
        "claude-code",
        "coaching",
        "champions"
      ],
      "runtime_docs": [
        "docs/runtime/claude-code.md"
      ]
    },
    {
      "name": "vgc-coach-opencode",
      "runtime": "opencode",
      "manifest_path": "package.json",
      "description": "Pokemon Champions coaching skills for OpenCode.",
      "keywords": [
        "pokemon",
        "vgc",
        "opencode",
        "coaching",
        "champions"
      ],
      "runtime_docs": [
        "docs/runtime/opencode.md"
      ]
    }
  ],
  "release_notes": {
    "summary": [
      "Generated Codex, Claude Code, and OpenCode plugin packages from the canonical shared skills tree.",
      "Published local marketplace metadata for Codex and Claude Code, plus git-install metadata for OpenCode.",
      "Kept `skills/` and `docs/skills/` as the only editable source of truth for shared coaching behavior."
    ]
  }
